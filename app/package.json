{
  "name": "ariadne-nyc-app",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "knip": "knip --no-exit-code",
    "lint:rust": "cd ../router && PATH=\"$HOME/.cargo/bin:$PATH\" cargo clippy --all-targets --no-deps && PATH=\"$HOME/.cargo/bin:$PATH\" cargo machete",
    "quality": "npm run check && npm run knip && npm run lint:rust",
    "route": "tsx scripts/route-cli.ts",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:a11y": "playwright test tests/a11y"
  },
  "dependencies": {
    "@huggingface/inference": "^4.13.15",
    "@huggingface/transformers": "^3.0.0",
    "@mlc-ai/web-llm": "^0.2.82",
    "fuse.js": "^7.3.0",
    "maplibre-gl": "^5.24.0",
    "minotor": "^11.1.3",
    "svelte": "^5.0.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.0",
    "@playwright/test": "^1.51.0",
    "@sveltejs/adapter-static": "^3.0.8",
    "@sveltejs/kit": "^2.16.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/geojson": "^7946.0.16",
    "knip": "^6.7.0",
    "svelte-check": "^4.0.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  }
}
